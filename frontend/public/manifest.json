{
    "manifest_version": 3,
    "name": "CyberX",
    "description": "Detects phishing and scam websites in real time and explains the risk in plain language.",
    "version": "1.0",
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "config.js",
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "permissions": [
        "activeTab",
        "storage",
        "webNavigation",
        "scripting",
        "contextMenus"
    ],
    "action": {
        "default_popup": "index.html",
        "default_icon": {
            "16": "images/Safora.png",
            "48": "images/Safora.png",
            "128": "images/Safora.png"
        }
    },
    "icons": {
        "16": "images/Safora.png",
        "48": "images/Safora.png",
        "128": "images/Safora.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "host_permissions": [
        "http://localhost:3000/*",
        "<all_urls>"
    ]
}